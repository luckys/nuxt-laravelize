{
  "name": "@luckys_luis/nuxt-laravelize",
  "version": "0.0.2",
  "description": "Nuxt module that brings Laravel-like architecture primitives to Nuxt and Nitro",
  "repository": "nuxt-laravelize/nuxt-laravelize",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && changelogen --release && pnpm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.5",
    "@standard-schema/spec": "^1.1.0",
    "awilix": "^12.0.5"
  },
  "peerDependencies": {
    "h3": ">=1.0.0",
    "nuxt": ">=4.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": { "optional": true },
    "ioredis": { "optional": true }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@luckys_luis/nuxt-laravelize-config": "^0.0.1",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.5",
    "@nuxt/test-utils": "^4.0.3",
    "@oxc-parser/binding-linux-x64-gnu": "^0.132.0",
    "@types/node": "latest",
    "bullmq": "^5.77.3",
    "changelogen": "^0.6.2",
    "eslint": "^9.39.1",
    "h3": "^1.15.11",
    "ioredis": "^5.10.1",
    "nuxt": "^4.4.5",
    "typescript": "^5.9.3",
    "valibot": "^1.4.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8",
    "zod": "^4.4.3"
  }
}
